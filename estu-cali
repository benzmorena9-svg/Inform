#include <stdio.h>

int main(){
    int cantidadEstudiantes;
    float calificacion;    
    float suma = 0.0;
    float promedio;
    float notaMasAlta, notaMasBaja;

    do {
        printf("Cantidad de estudiantes: \n");
        scanf("%d", &cantidadEstudiantes);

        if (cantidadEstudiantes <= 0) {
            printf("Error: la cantidad de estudiantes no puede ser negativa.\n");
        }
    } while (cantidadEstudiantes <= 0);

  
    for (int i = 1; i <= cantidadEstudiantes; i++) {

        do {
            printf("Ingrese la calificacion del estudiante(0-100) %d: ", i);
            scanf("%f", &calificacion);

            if (calificacion < 0 || calificacion > 100) {
                printf("Error: la calificacion debe estar entre 0 y 100. Intente nuevamente.\n");
            }
        } while (calificacion < 0 || calificacion > 100);

        if (i == 1) {
            notaMasAlta = calificacion;
            notaMasBaja = calificacion;
        } else {
            if (calificacion > notaMasAlta) {
                notaMasAlta = calificacion;
            }
            if (calificacion < notaMasBaja) {
                notaMasBaja = calificacion;
            }
        }

        suma += calificacion;
    }

    promedio = suma / cantidadEstudiantes;
    
    printf("Promedio: %.2f\n", promedio);
    printf("Calificacion Mayor: %.2f\n", notaMasAlta);
    printf("Calificacion Menor: %.2f\n", notaMasBaja);

    return 0;
}
